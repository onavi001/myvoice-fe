# Copia a .env (desarrollo) y .env.production (build Capacitor / Play Store).
# Obligatorio en producción: sin VITE_API_BASE_URL la app no llama al API.

VITE_API_BASE_URL=https://myvoice-be.vercel.app

# AdMob (solo app Android nativa; banner inferior con sesión iniciada)
# Crea unidades Banner e Interstitial en AdMob y pega los IDs en .env.production.
# Sin estas variables se usan IDs de prueba de Google en desarrollo.
# VITE_ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
# VITE_ADMOB_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/ZZZZZZZZZZ
# VITE_ADMOB_TESTING=false
# También sustituye admob_app_id en android/app/src/main/res/values/strings.xml

# AdSense (solo web PWA): bloque display en rutinas/progreso con contenido real
# Deja VITE_ADSENSE_ENABLED=false hasta que AdSense apruebe el sitio (evita infracción en pantallas vacías)
VITE_ADSENSE_ENABLED=false
VITE_ADSENSE_CLIENT=ca-pub-9321092696086358
VITE_ADSENSE_SLOT=4111146727

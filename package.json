{
  "name": "myvoice-fe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "host": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "assets:android": "npx @capacitor/assets generate --android --iconBackgroundColor '#1A1A1A' --iconBackgroundColorDark '#1A1A1A' --splashBackgroundColor '#1A1A1A' --splashBackgroundColorDark '#1A1A1A'",
    "mobile:build:android": "CAPACITOR=true npm run build && npx cap sync android",
    "mobile:build:ios": "CAPACITOR=true npm run build && npx cap sync ios",
    "mobile:bundle:android": "npm run mobile:build:android && cd android && ./gradlew bundleRelease",
    "mobile:apk:android": "npm run mobile:build:android && cd android && ./gradlew assembleRelease",
    "mobile:bundle:android:java21": "bash scripts/android-use-java21.sh npm run mobile:bundle:android",
    "mobile:apk:android:java21": "bash scripts/android-use-java21.sh npm run mobile:apk:android",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.6.1",
    "@tailwindcss/vite": "^4.1.3",
    "chart.js": "^4.4.8",
    "chartjs-plugin-zoom": "^2.2.0",
    "framer-motion": "^12.6.3",
    "js-cookie": "^3.0.5",
    "jspdf": "^4.2.1",
    "mongoose": "^8.13.2",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-calendar": "^5.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-datepicker": "^8.3.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.5.0",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-window": "^1.8.11",
    "styled-components": "^6.1.18",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.21.0",
    "@types/js-cookie": "^3.0.6",
    "@types/mongoose": "^5.11.96",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/react-window": "^1.8.8",
    "@types/serviceworker": "^0.0.127",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.0.0"
  }
}
